# ============================================================
# ملف قالب المتغيرات البيئية (.env.example)
# ============================================================
# انسخ هذا الملف وسمّه (.env) ثم املأ القيم الحقيقية.
# لا ترفع ملف (.env) الحقيقي إلى Git أبداً!
# ============================================================

# --- إعدادات التطبيق العامة ---
APP_NAME=my-project
APP_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000

# --- قاعدة البيانات ---
# (Supabase / Firebase / PostgreSQL / MySQL — حسب اختيار المشروع)
DATABASE_URL=
DATABASE_ANON_KEY=
DATABASE_SERVICE_ROLE_KEY=

# --- المصادقة (Authentication) ---
AUTH_SECRET=
AUTH_PROVIDER_CLIENT_ID=
AUTH_PROVIDER_CLIENT_SECRET=

# --- خدمات خارجية (Third-Party Services) ---
# أضف مفاتيح الخدمات الخارجية هنا حسب الحاجة
# STRIPE_SECRET_KEY=
# RESEND_API_KEY=
# CLOUDINARY_URL=
